%         isPilot = false(length(rxDataFinal), 1);
%         isPilot(pilotIndices) = true;
%         rxDataOnly = rxDataFinal(~isPilot);
% 
%         % ===== DEBUG Step0: 径向/切向误差分解 =====
%         symHat = qamdemod(rxDataOnly, M, "OutputType","integer", "UnitAveragePower", true);
%         sIdeal = qammod(double(symHat), M, "InputType","integer", "UnitAveragePower", true);
% 
%         e = rxDataOnly - sIdeal;
%         u = sIdeal ./ (abs(sIdeal)+1e-12);      % 径向单位向量
%         rad = real(e .* conj(u));               % 径向误差（幅度方向）
%         tan = imag(e .* conj(u));               % 切向误差（相位方向）
