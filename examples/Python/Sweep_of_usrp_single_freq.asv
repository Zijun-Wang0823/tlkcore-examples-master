%             fprintf('[WARN] Dropped samples occurred during capture.\n');
%         end
%         if size(rx,2) > 1
%             rx = rx(:,1);
%         end
% 
%         % Debug 1
%         rx0 = rx(:,1);
%         rx0 = rx0 - mean(rx0);
%         P_rx = mean(abs(rx0).^2);
%         P_rx_dB = 10*log10(P_rx + 1e-12);
%         fprintf("RX raw power = %.6g, %.2f dB\n", P_rx, P_rx_dB);
%         rmsv = sqrt(mean(abs(rx0).^2));
%         pk   = max(abs(rx0));
%         clip = mean(abs(rx0) > 0.98);
% 
%         fprintf("RX raw: rms=%.4g, pk=%.3f, clip=%.2f%%\n", rmsv, pk, 100*clip);
%         % Debug 1
% 
%         % --- Rx 处理 ---
