%             std(rad), std(tan), std(rad)/(std(tan)+1e-12));
% 
%         I = real(sIdeal); Q = imag(sIdeal);
%         Imax = max(abs(I)); Qmax = max(abs(Q));
%         isOuter = (abs(I) > 0.9*Imax) & (abs(Q) > 0.9*Qmax);
% 
%         evmOuter = rms(e(isOuter)) / (rms(sIdeal(isOuter)) + 1e-12);
%         evmInner = rms(e(~isOuter)) / (rms(sIdeal(~isOuter)) + 1e-12);
%         fprintf("EVM outer=%.4f, inner=%.4f, ratio=%.2f\n", evmOuter, evmInner, evmOuter/(evmInner+1e-12));
%         % ===========================================
% 
%         rxBitsHat = qamdemod(rxDataOnly, M, "OutputType","bit", "UnitAveragePower", true);
%         [numErr, ber] = biterr(dataBits, double(rxBitsHat(:)));
% 
%         fprintf('Frame:%4d | CFO:%8.1f Hz | RX SNR:%6.2f dB | BER: %.5f (Err:%d)\n', ...
%             frameCount, CFO_est, snrRx_dB, ber, numErr);
% 
%         set(hScatter, 'XData', real(rxDataOnly), 'YData', imag(rxDataOnly));
%         title(ax, sprintf('Frame:%d | CFO: %.0f Hz | BER: %.4f', frameCount, CFO_est, ber));
%         drawnow limitrate;
% 
%     catch ME
%         fprintf('Error: %s\n', ME.message);
%         rethrow(ME);
%     end
% end
%% ----------------- 6'. 2D DFT codebook 扫描 -----------------
TX_SN = "BDA-2550009-2800";
RX_SN = "BDA-2550019-2800";

tlk = py.importlib.import_module('tlkcore_bridge');
py.importlib.reload(tlk);
tlk.init(py.list({TX_SN, RX_SN}));
tlk.set_tx(TX_SN);  tlk.set_rx(RX_SN);

% ---- DFT codebook ----
Naz = 15;  Nel = 9;
u_grid = linspace(sin(deg2rad(-60)), sin(deg2rad(60)), Naz);
v_grid = linspace(sin(deg2rad(-30)), sin(deg2rad(30)), Nel);
[U, V] = meshgrid(u_grid, v_grid);
AZ = rad2deg(asin(U));
EL = rad2deg(asin(V));

dx = sind(AZ) .* cosd(EL);
dy = sind(EL);
dz = cosd(AZ) .* cosd(EL);
THETA = rad2deg(acos(dz));
PHI   = mod(rad2deg(atan2(dy, dx)), 360);
THETA(abs(AZ)<1e-6 & abs(EL)<1e-6) = 0;
PHI(abs(AZ)<1e-6 & abs(EL)<1e-6)   = 0;

metric = nan(Nel, Naz);

tlk.set_beam(RX_SN, int32(0), int32(0));
pause(0.1);

% USRP 继续 continuous
transmit(bbtrx, txWave, "continuous");

total = Naz * Nel;
tic;
for ii = 1:Nel
    for jj = 1:Naz
        if ~ishandle(f), break; end
        th = int32(round(THETA(ii,jj)));
        ph = int32(round(PHI(ii,jj)));
        tlk.set_beam(TX_SN, th, ph);
        pause(0.03);

        [rx, ~, ~] = capture(bbtrx, capLen);
        if size(rx,2) > 1, rx = rx(:,1); end

        % ===== 简化指标：用匹配滤波 + STF 峰值做 RSSI =====
        try
            rx = rx - mean(rx);
            rxMF = rxRRC(rx);
            Ls = Lrep * sps;
            searchSamp = length(rxMF) - 2*Ls - 1;
            P = complex(zeros(searchSamp,1,'like',rxMF));
            R = zeros(searchSamp,1,'like',real(rxMF));
            for m = 1:2:searchSamp
                a = rxMF(m:m+Ls-1);
                b = rxMF(m+Ls:m+2*Ls-1);
                P(m) = sum(b .* conj(a));
                R(m) = sum(abs(b).^2);
            end
            Mstf = (abs(P).^2) ./ (R.^2 + 1e-9);
            Mstf(1:50*sps) = 0;
            metric(ii,jj) = max(Mstf);    % STF 相关峰 = 该波束下信道强度代理
        catch
            metric(ii,jj) = NaN;
        end

        done = (ii-1)*Naz + jj;
        fprintf('[%3d/%3d] az=%+5.1f° el=%+5.1f° θ=%2d° φ=%3d° metric=%.3f\n', ...
            done, total, AZ(ii,jj), EL(ii,jj), th, ph, metric(ii,jj));
    end
end
fprintf('Sweep done in %.1f s\n', toc);
stopTransmission(bbtrx);

% ===== 找最佳 codeword =====
[bestVal, linIdx] = max(metric(:));
[bestEl, bestAz]  = ind2sub(size(metric), linIdx);
fprintf('>>> Best: az=%+.1f° el=%+.1f° (θ=%d° φ=%d°)  metric=%.3f\n', ...
    AZ(bestEl,bestAz), EL(bestEl,bestAz), ...
    round(THETA(bestEl,bestAz)), round(PHI(bestEl,bestAz)), bestVal);

% ===== 热力图 =====
figure('Name','Codebook Heatmap','Color','w');
imagesc(u_grid, v_grid, 10*log10(metric+1e-12));
set(gca,'YDir','normal'); axis image; colorbar; colormap jet;
xlabel('sin(az) = u'); ylabel('sin(el) = v');
title('DFT Codebook Response (dB)');
hold on; plot(U(bestEl,bestAz), V(bestEl,bestAz), 'w*', 'MarkerSize',15,'LineWidth',2);

% 锁到最佳
tlk.set_beam(TX_SN, int32(round(THETA(bestEl,bestAz))), int32(round(PHI(bestEl,bestAz))));
tlk.shutdown(py.list({TX_SN, RX_SN}));
%% ====== 辅助函数 ======
function r = sample1sps_interp(x, tau, sps)
x = x(:); N = length(x);
idx = (1+tau) : sps : (N-2*sps);
t = (1:N).';
r = interp1(t, x, idx, 'pchip').';
end

function y = fse_nlms_train_only(x, t0, sps, Nsym, dTrain, Ntaps, mu)
if mod(Ntaps,2)==0, Ntaps = Ntaps+1; end
ref = (Ntaps+1)/2;
x = x(:);
y = complex(zeros(Nsym,1));
w = complex(zeros(Ntaps,1));
w(ref) = 1;
for m = 1:Nsym
    t = t0 + (m-1)*sps;
    i1 = t - (ref-1);
    i2 = t + (Ntaps-ref);
    if i1 < 1 || i2 > length(x), break; end
    xv = x(i1:i2);
    y(m) = w' * xv;
    if m <= length(dTrain)
        e = dTrain(m) - y(m);
        w = w + (mu/(real(xv'*xv)+1e-6)) * xv * conj(e);
    end
end
end

function cleanupRadio(bbtrx)
try, stopTransmission(bbtrx); catch, end
try, clear bbtrx; catch, end
end

function closeFigureStopTx(figHandle, bbtrx)
try, stopTransmission(bbtrx); catch, end
delete(figHandle);
end