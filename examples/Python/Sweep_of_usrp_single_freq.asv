%         % Debug 2: per-frame receive SNR estimated from training symbols
%         rxTrain = rxEq(1:NtrainSym);
%         eTrain  = rxTrain - trainSym;
% 
%         sigPow = mean(abs(trainSym).^2);
%         noiPow = mean(abs(eTrain).^2);
