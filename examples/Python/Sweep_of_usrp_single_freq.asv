clear all; clc; close all;
set(0, 'DefaultFigureWindowStyle', 'normal');

%% ----------------- 1. 参数定义 -----------------
M   = 16; k = log2(M); sps = 2;
Rs  = 1e6/sps; Fs = Rs*sps;
rolloff = 0.35; span = 10;
NpadSym = 100;

Npreamble = 2048; Lrep = 32; Nstf = 1024; Nltf = Npreamble - Nstf; NtrainSym = 2000;

PilotSpacing = 10;
NumDataBlocks = 400;
LenDataBlock = PilotSpacing - 1;
NdataSymTotal = NumDataBlocks * LenDataBlock;

FixedPilotVal = (1+1j)/sqrt(2);
% rng(7);

%% ----------------- 2. 初始化 -----------------
repBlock = pskmod(randi([0 3], Lrep, 1), 4, pi/4);
stfSym   = repmat(repBlock, Nstf/Lrep, 1);
ltfSym   = pskmod(randi([0 3], Nltf, 1), 4, pi/4);
preambleSym = [stfSym; ltfSym];

txRRC = comm.RaisedCosineTransmitFilter("RolloffFactor", rolloff, ...
    "FilterSpanInSymbols", span, "OutputSamplesPerSymbol", sps);
rxRRC = comm.RaisedCosineReceiveFilter("RolloffFactor", rolloff, ...
    "FilterSpanInSymbols", span, "InputSamplesPerSymbol", sps, "DecimationFactor", 1);
agc = comm.AGC("AveragingLength", 100, "DesiredOutputPower", 1, "MaxPowerGain", 60);

%% ----------------- 3. USRP X410 配置 -----------------
radioID   = "tempRadio";
fc_Hz     = 5.2e9;
txGain_dB = 10;
rxGain_dB = 0;

txAntenna = "DB0:RF0:TX/RX0";
rxAntenna = "DB0:RF0:RX1";

bbtrx = basebandTransceiver(radioID, ...
    TransmitAntennas=txAntenna, ...
    CaptureAntennas=rxAntenna, ...
    DroppedSamplesAction="warning", ...
    TransmitDataType="single", ...
    CaptureDataType="single");

bbtrx.SampleRate              = Fs;
bbtrx.TransmitCenterFrequency = fc_Hz;
bbtrx.CaptureCenterFrequency  = fc_Hz;
bbtrx.TransmitRadioGain       = txGain_dB;
bbtrx.CaptureRadioGain        = rxGain_dB;

% 退出时尽力停发射
cleanupObj = onCleanup(@()cleanupRadio(bbtrx));

saveFile = fullfile(pwd, ['rxDistanceinch_' datestr(now,'yyyymmdd_HHMMSS') '.mat']);
rx_frames = {};
fprintf('RX frames will be saved to:\n%s\n', saveFile);

%% ----------------- 4. GUI 窗口 -----------------
f = figure('Name', 'Real-Time 64QAM OTA (X410)', 'Color', 'w', ...
    'NumberTitle', 'off', 'MenuBar', 'none');
ax = axes('Parent', f);
hScatter = plot(ax, 0, 0, '.', 'MarkerSize', 6);
grid(ax, 'on');
axis(ax, 'square');
axis(ax, [-2 2 -2 2]);
xlabel(ax, 'I');
ylabel(ax, 'Q');
title(ax, 'Initializing...');

% 关窗口停发射
f.CloseRequestFcn = @(src,evt)closeFigureStopTx(src, bbtrx);

%% ----------------- 5. 先生成一帧并 continuous 发射 -----------------
% 帧结构：pad + preamble + train + payload
padSym = pskmod(randi([0 3], NpadSym, 1), 4, pi/4);

trainBits = randi([0 1], NtrainSym*k, 1);
trainSym = qammod(trainBits, M, "InputType","bit", "UnitAveragePower", true);

dataBits = randi([0 1], NdataSymTotal*k, 1);
dataSymRaw = qammod(dataBits, M, "InputType","bit", "UnitAveragePower", true);

dataMatrix = reshape(dataSymRaw, LenDataBlock, NumDataBlocks);
pilotRow   = repmat(FixedPilotVal, 1, NumDataBlocks);
payloadSym = reshape([dataMatrix; pilotRow], [], 1);

% guard，避免 continuous 粘帧
txSym = [padSym; preambleSym; trainSym; payloadSym; zeros(4*span,1)];

reset(txRRC);
txWave = txRRC(txSym);

% scale
txWave = txWave / (max(abs(txWave)) + 1e-12);
txWave = single(0.7 * txWave);

frameLenSamp = length(txWave);
capLen = 3 * frameLenSamp;  % 抓长一点，保证含一整帧

% transmit(bbtrx, txWave, "continuous");  % continuous 发射

% %% ----------------- 6. 主循环 -----------------
% frameCount = 0;
% while ishandle(f)
%     frameCount = frameCount + 1;
% 
%     try
%         [rx, ~, droppedSamples] = capture(bbtrx, capLen);
